            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "accordion_JgDwak": {
          "type": "accordion",
          "name": "t:names.accordion",
          "settings": {
            "icon": "caret",
            "dividers": true,
            "type_preset": "h5",
            "inherit_color_scheme": true,
            "color_scheme": "",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "accordion_row_mtRRm8": {
              "type": "_accordion-row",
              "settings": {
                "heading": "¿Qué tipo de proyectos realizamos?",
                "open_by_default": false
              },
              "blocks": {
                "text_4PApYW": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Diseñamos, fabricamos e instalamos soluciones en madera para exterior y uso habitable: casas, casetas, estudios, oficinas de jardín, porches, pérgolas, cenadores, tarimas y proyectos a medida.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_4PApYW"
              ]
            },
            "accordion_row_nitzye": {
              "type": "_accordion-row",
              "settings": {
                "heading": "¿Trabajamos solo modelos estándar o también proyectos a medida?",
                "open_by_default": false
              },
              "blocks": {
                "text_VYUfAk": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Trabajamos ambas opciones. Existen modelos base para agilizar tiempos, pero gran parte de los proyectos se adaptan en medidas, distribución, acabados, aislamiento y detalles técnicos.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_VYUfAk"
              ]
            },
            "accordion_row_39fNfG": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Se puede usar una construcción de madera como vivienda, oficina o estudio?",
                "open_by_default": false
              },
              "blocks": {
                "text_fCkWBc": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sí, siempre que el proyecto esté diseñado para ese uso y cumpla los requisitos técnicos y urbanísticos aplicables. No es lo mismo una caseta auxiliar que un espacio habitable o de uso permanente.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_fCkWBc"
              ]
            },
            "accordion_row_VFGeaN": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Qué necesito para pedir presupuesto?",
                "open_by_default": false
              },
              "blocks": {
                "text_k8HCHE": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Lo ideal es facilitar el uso previsto, medidas aproximadas, ubicación del proyecto, fotografías del terreno o espacio, y cualquier plano, croquis o referencia que ayude a definir la propuesta.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_k8HCHE"
              ]
            },
            "accordion_row_wAFJ7w": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Se realiza diseño previo antes de fabricar?",
                "open_by_default": false
              },
              "blocks": {
                "text_b6Tpez": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sí. Definir bien el diseño antes de fabricar permite ajustar mejor el presupuesto, prever detalles técnicos y evitar cambios posteriores en obra.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_b6Tpez"
              ]
            },
            "accordion_row_3VWYn8": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Se puede instalar en cualquier parcela?",
                "open_by_default": false
              },
              "blocks": {
                "text_McbVxE": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>No siempre. Antes de confirmar un proyecto conviene revisar accesos, pendientes, retranqueos, normativa, uso permitido y condiciones del terreno.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_McbVxE"
              ]
            },
            "accordion_row_7jHiYj": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Puedo personalizar acabados, revestimientos y distribución?",
                "open_by_default": false
              },
              "blocks": {
                "text_x8XbXd": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sí. Se pueden adaptar medidas, estética exterior, distribución interior, carpinterías, revestimientos, aislamiento y múltiples detalles para ajustarlos al uso real del espacio.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_x8XbXd"
              ]
            },
            "accordion_row_hQteFY": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Qué solución encaja mejor para un estudio de jardín o una oficina exterior?",
                "open_by_default": false
              },
              "blocks": {
                "text_bm6wM4": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Para un uso frecuente o intensivo, conviene priorizar confort térmico, aislamiento acústico, calidad de carpinterías y una envolvente bien resuelta. La solución se define según el nivel de uso previsto durante todo el año.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_bm6wM4"
              ]
            },
            "accordion_row_n8qe6p": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Por qué elegir una solución en madera frente a una obra tradicional?",
                "open_by_default": false
              },
              "blocks": {
                "text_pzGFxm": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Porque permite combinar diseño, rapidez, eficiencia, imagen cuidada y un proceso más controlado. Además, ofrece un alto nivel de personalización y una construcción más ligera y versátil.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_pzGFxm"
              ]
            },
            "accordion_row_hmD7j6": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Cómo saber qué solución encaja mejor con el presupuesto disponible?",
                "open_by_default": false
              },
              "blocks": {
                "text_9k8x3h": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>La mejor forma es valorar el proyecto completo, no solo el precio base. Hay que comparar sistema constructivo, aislamiento, acabados, base, transporte, montaje y uso real del espacio.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_9k8x3h"
              ]
            },
            "accordion_row_Y68XVG": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Cómo empezar?",
                "open_by_default": false
              },
              "blocks": {
                "text_pPAQ4R": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Solo hace falta explicar qué se quiere construir, para qué se va a utilizar y dónde se va a instalar. A partir de ahí se puede orientar la solución más adecuada y preparar una propuesta realista.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",

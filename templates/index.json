    "section_3VgnV7": {
      "type": "section",
      "blocks": {
        "text_cMy8JL": {
          "type": "text",
          "name": "t:names.heading",
          "settings": {
            "text": "<p><strong>Preguntas frecuentes de clientes sobre casas y soluciones de madera</strong></p>",
            "width": "100%",
            "max_width": "none",

              ]
            },
            "accordion_row_tCP3Wd": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Qué incluye normalmente el servicio?",
                "open_by_default": false
              },
              "blocks": {
                "text_8nFJFw": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Según el proyecto, puede incluir asesoramiento, diseño, definición técnica, fabricación, transporte, montaje, base, protección de la madera y soporte postventa.</p>",
                    "width": "fit-content",
                    "max_width": "none",

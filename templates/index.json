                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_pwTDN8"
              ]
            },
            "accordion_row_LefF9K": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "¿Ofrecemos servicio postventa?",
                "open_by_default": false
              },
              "blocks": {
                "text_hP7p6A": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sí. El servicio postventa está pensado para dar continuidad al proyecto una vez instalado, resolver incidencias y acompañar al cliente en el mantenimiento o en posibles ajustes posteriores.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [

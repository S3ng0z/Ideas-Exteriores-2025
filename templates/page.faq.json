  "sections": {
    "custom_liquid_chGEnT": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n  .lux-breadcrumb-box {\n    padding: 1rem 0;\n  }\n\n  .lux-breadcrumb-inner {\n    display: flex;\n    flex-direction: column;\n    gap: 0.5rem;\n  }\n\n  .lux-breadcrumb {\n    display: flex;\n    flex-wrap: wrap;\n    align-items: center;\n    font-size: 0.875rem;\n    line-height: 1.4;\n  }\n\n  .lux-breadcrumb a {\n    text-decoration: none;\n  }\n\n  .lux-breadcrumb a:hover {\n    text-decoration: underline;\n  }\n\n  .lux-breadcrumb-separator {\n    margin: 0 0.35rem;\n  }\n\n  .lux-breadcrumb .current {\n    font-weight: 600;\n  }\n\n  .lux-title {\n    font-size: 1.8rem;\n    line-height: 1.2;\n  }\n\n  /* Tablet */\n  @media (max-width: 1024px) {\n    .lux-title {\n      font-size: 1.5rem;\n    }\n\n    .lux-breadcrumb {\n      font-size: 0.8rem;\n    }\n  }\n\n  /* Smartphone */\n  @media (max-width: 640px) {\n    .lux-breadcrumb-inner {\n      gap: 0.25rem;\n    }\n\n    .lux-breadcrumb {\n      font-size: 0.75rem;\n    }\n\n    .lux-title {\n      font-size: 1.25rem;\n    }\n\n    .lux-breadcrumb .current {\n      white-space: nowrap;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      max-width: 100%;\n    }\n  }\n</style>\n\n<div class=\"lux-breadcrumb-box page-width-content\">\n  <div class=\"lux-breadcrumb-inner\">\n    <nav class=\"lux-breadcrumb\" aria-label=\"breadcrumbs\">\n      {%- comment -%} Enlace a INICIO {%- endcomment -%}\n      <a href=\"{{ routes.root_url }}\">INICIO</a>\n\n      {%- comment -%}\n        Metafields (ajusta \"custom\" si usas otro namespace)\n      {%- endcomment -%}\n      {% assign n1      = page.metafields.custom.n1      | default: page.metafields.custom.N1 %}\n      {% assign n1_url  = page.metafields.custom.n1_url  | default: page.metafields.custom.N1_URL %}\n      {% assign n2      = page.metafields.custom.n2      | default: page.metafields.custom.N2 %}\n      {% assign n2_url  = page.metafields.custom.n2_url  | default: page.metafields.custom.N2_URL %}\n      {% assign n3      = page.metafields.custom.n3      | default: page.metafields.custom.N3 %}\n      {% assign n3_url  = page.metafields.custom.n3_url  | default: page.metafields.custom.N3_URL %}\n\n      {%- comment -%}\n        Función “manual” para extraer solo el path de una URL:\n        - Quita http:// y https://\n        - Separa por \"/\"\n        - Ignora el primer elemento (dominio) y reconstruye /lo/que/sea\n      {%- endcomment -%}\n\n      {%- assign n1_path = '' -%}\n      {%- if n1_url != blank -%}\n        {% assign n1_clean = n1_url | remove: 'https://' | remove: 'http://' %}\n        {% assign n1_parts = n1_clean | split: '/' %}\n        {% assign n1_path = '' %}\n        {% for part in n1_parts %}\n          {% if forloop.first %}\n          {% else %}\n            {% if part != blank %}\n              {% assign n1_path = n1_path | append: '/' | append: part %}\n            {% endif %}\n          {% endif %}\n        {% endfor %}\n      {%- endif -%}\n\n      {%- assign n2_path = '' -%}\n      {%- if n2_url != blank -%}\n        {% assign n2_clean = n2_url | remove: 'https://' | remove: 'http://' %}\n        {% assign n2_parts = n2_clean | split: '/' %}\n        {% assign n2_path = '' %}\n        {% for part in n2_parts %}\n          {% if forloop.first %}\n          {% else %}\n            {% if part != blank %}\n              {% assign n2_path = n2_path | append: '/' | append: part %}\n            {% endif %}\n          {% endif %}\n        {% endfor %}\n      {%- endif -%}\n\n      {%- assign n3_path = '' -%}\n      {%- if n3_url != blank -%}\n        {% assign n3_clean = n3_url | remove: 'https://' | remove: 'http://' %}\n        {% assign n3_parts = n3_clean | split: '/' %}\n        {% assign n3_path = '' %}\n        {% for part in n3_parts %}\n          {% if forloop.first %}\n          {% else %}\n            {% if part != blank %}\n              {% assign n3_path = n3_path | append: '/' | append: part %}\n            {% endif %}\n          {% endif %}\n        {% endfor %}\n      {%- endif -%}\n\n      {%- comment -%}\n        Si ya venía como \"/pages/xxx\", el sistema sigue funcionando porque:\n        \"/pages/xxx\" sin protocolo → primer elemento \"\" (dominio vacío) y luego \"pages\", \"xxx\" → /pages/xxx\n      {%- endcomment -%}\n\n      {%- comment -%} N1 {%- endcomment -%}\n      {% if n1 != blank %}\n        <span class=\"lux-breadcrumb-separator\">/</span>\n        {% if n1_path != blank %}\n          <a href=\"{{ n1_path }}\">{{ n1 }}</a>\n        {% else %}\n          <span>{{ n1 }}</span>\n        {% endif %}\n      {% endif %}\n\n      {%- comment -%} N2 {%- endcomment -%}\n      {% if n2 != blank %}\n        <span class=\"lux-breadcrumb-separator\">/</span>\n        {% if n2_path != blank %}\n          <a href=\"{{ n2_path }}\">{{ n2 }}</a>\n        {% else %}\n          <span>{{ n2 }}</span>\n        {% endif %}\n      {% endif %}\n\n      {%- comment -%} N3 {%- endcomment -%}\n      {% if n3 != blank %}\n        <span class=\"lux-breadcrumb-separator\">/</span>\n        {% if n3_path != blank %}\n          <a href=\"{{ n3_path }}\">{{ n3 }}</a>\n        {% else %}\n          <span>{{ n3 }}</span>\n        {% endif %}\n      {% endif %}\n\n      {%- comment -%} Página actual {%- endcomment -%}\n      <span class=\"lux-breadcrumb-separator\">/</span>\n      <span class=\"current\">{{ page.title }}</span>\n    </nav>\n\n    <h1 class=\"lux-title\">{{ page.title }}</h1>\n  </div>\n</div>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }

                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_MHbrTz"
              ]
            },
            "accordion_row_xDgjTH": {
              "type": "_accordion-row",
              "settings": {
                "heading": "¿También se realizan cimentación, bases o soleras?",
                "open_by_default": false
              },
              "blocks": {
                "text_Q6XxPH": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Sí, según el proyecto. La base es una parte fundamental para asegurar estabilidad, nivelación, drenaje y una correcta durabilidad de la estructura.</p>",
                    "width": "fit-content",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",

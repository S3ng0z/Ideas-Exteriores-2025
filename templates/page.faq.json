                "open_by_default": false
              },
              "blocks": {
                "text_FCyaDa": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Solo hace falta explicar qué se quiere construir, para qué se va a utilizar y dónde se va a instalar. A partir de ahí se puede orientar la solución más adecuada y preparar una propuesta realista.</p>",
                    "width": "fit-content",

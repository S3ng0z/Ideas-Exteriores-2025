                "custom_liquid": "<!-- WhatsApp Floating Button --><div class=\"whatsapp-container\"><a href=\"https://wa.me/34687480356\" target=\"_blank\" aria-label=\"Contáctanos por WhatsApp\"><img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5e/WhatsApp_icon.png\" alt=\"WhatsApp\" class=\"whatsapp-icon\"></a><div class=\"whatsapp-tooltip\">¿En qué puedo ayudarte?</div></div><style>.whatsapp-container{position:fixed;bottom:50px;left:50px;z-index:9999}.whatsapp-icon{width:60px;height:60px;cursor:pointer}.whatsapp-tooltip{display:none;position:absolute;bottom:70px;left:0;background:#25D366;color:#fff;padding:10px 15px;border-radius:20px;white-space:nowrap;opacity:0;transition:opacity .5s,transform .5s;transform:translateY(10px);box-shadow:0 4px 10px rgba(0,0,0,.2)}.whatsapp-tooltip.show{display:block;opacity:1;transform:translateY(0)}@media (max-width:1024px){.whatsapp-container{bottom:25px;left:15px}}</style><script>document.addEventListener(\"DOMContentLoaded\",function(){setTimeout(function(){var t=document.querySelector(\".whatsapp-tooltip\");t&&t.classList.add(\"show\")},2000)});</script>"

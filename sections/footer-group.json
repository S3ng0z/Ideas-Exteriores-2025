            "custom_liquid_97d6aG": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{%- comment -%}\n  Floating buttons:\n  1) Download corporate dossier without leaving the current page\n     - Primary method: fetch + Blob + temporary link\n     - Fallback: open PDF in new tab\n  2) Back to top button\n     - Hidden at top\n     - Appears on scroll with smooth fade/slide\n     - Elegant smooth scroll to top\n\n  Recomendado:\n  - Pegar este bloque en theme.liquid justo antes de </body>\n{%- endcomment -%}\n\n<div class=\"ie-floating-buttons\">\n  <button\n    type=\"button\"\n    class=\"ie-floating-btn ie-scroll-top-btn\"\n    id=\"ieScrollTopBtn\"\n    aria-label=\"Volver arriba\"\n    title=\"Volver arriba\"\n  >\n    <span class=\"ie-arrow-wrap\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" class=\"ie-arrow-icon\" aria-hidden=\"true\">\n        <path d=\"M12 19V6\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n        <path d=\"M6.75 11.25L12 6l5.25 5.25\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </span>\n  </button>\n<button\n    type=\"button\"\n    class=\"ie-floating-btn ie-dossier-btn\"\n    id=\"ieDossierBtn\"\n    aria-label=\"Descargar dossier corporativo\"\n    title=\"Descargar dossier corporativo\"\n  >\n    <img src=\"https://cdn.shopify.com/s/files/1/0921/0796/4760/files/Download_dossier.webp?v=1775063817\"\n      alt=\"Descargar dossier corporativo\"\n      loading=\"lazy\"\n    >\n  </button>\n</div>\n\n<style>\n  .ie-floating-buttons {\n    position: fixed;\n    right: 50px;\n    bottom: 50px;\n    z-index: 9999;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n    align-items: center;\n  }\n\n  .ie-floating-btn {\n    border: 0;\n    padding: 0;\n    margin: 0;\n    background: transparent;\n    cursor: pointer;\n    -webkit-appearance: none;\n    appearance: none;\n  }\n\n  .ie-dossier-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: transform 0.25s ease, opacity 0.25s ease, filter 0.25s ease;\n  }\n\n  .ie-dossier-btn:hover {\n    transform: translateY(-2px) scale(1.03);\n    filter: saturate(1.03);\n  }\n\n  .ie-dossier-btn img {\n    display: block;\n    width: 75px;\n    height: 75px;\n    object-fit: contain;\n  }\n\n  .ie-scroll-top-btn {\n    width: 54px;\n    height: 54px;\n    border-radius: 999px;\n    background: rgba(17, 17, 17, 0.88);\n    backdrop-filter: blur(6px);\n    -webkit-backdrop-filter: blur(6px);\n    color: #ffffff;\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    opacity: 0;\n    visibility: hidden;\n    transform: translateY(10px) scale(0.96);\n    pointer-events: none;\n    transition:\n      opacity 0.28s ease,\n      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1),\n      visibility 0.28s ease,\n      background 0.25s ease,\n      box-shadow 0.25s ease;\n  }\n\n  .ie-scroll-top-btn.is-visible {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0) scale(1);\n    pointer-events: auto;\n  }\n\n  .ie-scroll-top-btn:hover {\n    background: rgba(17, 17, 17, 0.96);\n    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);\n  }\n\n  .ie-scroll-top-btn:active {\n    transform: translateY(1px) scale(0.97);\n  }\n\n  .ie-arrow-wrap {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: transform 0.28s ease;\n  }\n\n  .ie-scroll-top-btn:hover .ie-arrow-wrap {\n    transform: translateY(-2px);\n  }\n\n  .ie-arrow-icon {\n    width: 22px;\n    height: 22px;\n    display: block;\n  }\n\n  @media (max-width: 1024px) {\n    .ie-floating-buttons {\n      right: 15px;\n      bottom: 15px;\n      gap: 10px;\n    }\n\n    .ie-dossier-btn img {\n      width: 56px;\n      height: 56px;\n    }\n\n    .ie-scroll-top-btn {\n      width: 48px;\n      height: 48px;\n    }\n\n    .ie-arrow-icon {\n      width: 20px;\n      height: 20px;\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .ie-dossier-btn,\n    .ie-scroll-top-btn,\n    .ie-arrow-wrap {\n      transition: none;\n    }\n\n    html {\n      scroll-behavior: auto;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    var scrollTopBtn = document.getElementById('ieScrollTopBtn');\n    var dossierBtn = document.getElementById('ieDossierBtn');\n    var dossierUrl = 'https://cdn.shopify.com/s/files/1/0921/0796/4760/files/Conoce_Ideas_Exteriores_-_Especialistas_en_Madera.pdf?v=1773865931';\n    var dossierFileName = 'Conoce_Ideas_Exteriores_-_Especialistas_en_Madera.pdf';\n\n    function toggleScrollTopBtn() {\n      if (window.scrollY > 80) {\n        scrollTopBtn.classList.add('is-visible');\n      } else {\n        scrollTopBtn.classList.remove('is-visible');\n      }\n    }\n\n    function downloadFile(url, filename) {\n      fetch(url, { mode: 'cors' })\n        .then(function(response) {\n          if (!response.ok) {\n            throw new Error('No se pudo descargar el archivo.');\n          }\n          return response.blob();\n        })\n        .then(function(blob) {\n          var blobUrl = window.URL.createObjectURL(blob);\n          var tempLink = document.createElement('a');\n\n          tempLink.href = blobUrl;\n          tempLink.download = filename;\n          document.body.appendChild(tempLink);\n          tempLink.click();\n          document.body.removeChild(tempLink);\n\n          setTimeout(function() {\n            window.URL.revokeObjectURL(blobUrl);\n          }, 1000);\n        })\n        .catch(function() {\n          window.open(url, '_blank', 'noopener');\n        });\n    }\n\n    dossierBtn.addEventListener('click', function () {\n      downloadFile(dossierUrl, dossierFileName);\n    });\n\n    scrollTopBtn.addEventListener('click', function () {\n      window.scrollTo({\n        top: 0,\n        behavior: 'smooth'\n      });\n    });\n\n    window.addEventListener('scroll', toggleScrollTopBtn, { passive: true });\n    toggleScrollTopBtn();\n  });\n</script>"
              },
